{
  "ConnectionStrings": {
    "FabricWarehouse": "Server=tcp:<fabric-workspace-or-sql-endpoint>.datawarehouse.fabric.microsoft.com,1433;Initial Catalog=<warehouse-name>;Encrypt=True;TrustServerCertificate=False;Authentication=Active Directory Default;"
  },
  "AllowedOrigins": [
    "http://localhost:5173"
  ],
  "OpenAI": {
    "Provider": "AzureOpenAI",
    "Endpoint": "https://<your-resource>.openai.azure.com",
    "ApiKey": "<OPENAI_OR_AZURE_OPENAI_API_KEY>",
    "Model": "<deployment-or-model-name>",
    "ApiVersion": "2024-10-21",
    "Temperature": 0.1,
    "MaxTokens": 1600
  },
  "Warehouse": {
    "DefaultSchema": "dbo",
    "AllowedTables": [
      "TrxDetails",
      "FactSales",
      "FactInspections",
      "Fact Inspections",
      "FactMediaDetails",
      "VoucherTransactionDetails"
    ],
    "MaxRows": 500,
    "CommandTimeoutSeconds": 120,
    "SchemaCacheMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
